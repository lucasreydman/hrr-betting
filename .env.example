# HRR Betting — example environment file.
# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# Without these, `npm run dev` still boots:
#   - lib/kv.ts falls back to an in-memory Map (no persistence between restarts).
#   - lib/db.ts (Supabase) becomes a no-op.
#   - lib/cron-auth.ts opens cron routes (production fails closed).
# These vars are required for production-parity behaviour and for any code path
# that needs to read or write Supabase.

# Supabase project URL. Get from Supabase dashboard → Project Settings → API.
SUPABASE_URL=

# Supabase service-role key. Bypasses Row Level Security.
# SERVER-ONLY — never expose to the browser or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret sent as the `x-cron-secret` header by the GitHub Actions cron.
# Required in production: routes under /api/sim, /api/refresh, /api/lock,
# /api/settle, /api/admin/bvp 401 every caller without it.
# The same value must be set as a GitHub Actions repo secret.
CRON_SECRET=

# Optional. Set to 1 to opt into live-network smoke tests against MLB Stats,
# Baseball Savant, and Open-Meteo. Off by default so `npm test` stays hermetic.
# RUN_LIVE_TESTS=1
